# ── 部署設定範本 ──────────────────────────────────────────────
# 複製此檔為 .env.local 並填入各自的值。複製系統給新組織時，
# 每個組織用自己的 Supabase 專案 + 自己的這份設定。

# 系統品牌名稱（顯示於標題列、登入頁、分頁標題、匯出檔作者）
NEXT_PUBLIC_APP_NAME=星光超級表格系統

# ── Supabase（在 Supabase Dashboard → Settings → API 取得）────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
# 僅伺服器端使用、絕不可外流：
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Session 簽章用的隨機字串（自行產生一段亂數）
AUTH_SECRET=<random-secret-string>

# ── 種子腳本用（npm run seed:admin）建立第一個系統管理者 ───────
# 這兩個變數只在執行 seedSuperadmin.ts 時需要，不放進正式環境
# SUPABASE_URL=（同上 NEXT_PUBLIC_SUPABASE_URL）
# SUPABASE_SERVICE_KEY=（同上 SUPABASE_SERVICE_ROLE_KEY）
# SUPERADMIN_USERNAME=admin@example.com
# SUPERADMIN_PASSWORD=（初始密碼，至少 8 字元；首次登入會強制改）
